// =====================
// Prisma Schema: Loan Management System
// =====================
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma-client"
}

// Counter table used to generate unique loan numbers per year
model LoanNumberCounter {
  year      Int      @id
  sequence  Int      @default(0)
  updatedAt DateTime @updatedAt
}

datasource db {
  provider = "mysql"
  // Connection URL moved to prisma.config.ts per Prisma 7+ requirements
}

// =================================USERS=====================================

model User {
  id            String   @id @default(cuid())
  fullName      String
  userName      String   @unique
  email         String   @unique
  password      String
  role          Role
  contactNumber String
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kycStatus KycStatus @default(PENDING)

  // Relations
  profile  UserProfile?
  admin    Admin?
  partner  Partner?
  employee Employee?

  kycs                  Kyc[]
  permissions           UserPermission[]
  leadsAssignedTo       Leads[]                @relation("LeadAssignedTo")
  leadsAssignedBy       Leads[]                @relation("LeadAssignedBy")
  verifiedKycs          Kyc[]                  @relation("KycVerifiedBy")
  loanApplications      LoanApplication[]
  loanApplicationDrafts LoanApplicationDraft[]
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  dob            DateTime
  gender         String
  meritalStatus  String
  educationLevel String
  occupation     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])
}

model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Relations
  user      User     @relation(fields: [userId], references: [id])
}

model Employee {
  id                 String        @id @default(cuid())
  userId             String        @unique
  fullName           String
  Email              String        @unique
  contactNumber      String
  reportingManagerId String?
  employeeId         String        @unique
  employeeRoleId     String?
  atlMobileNumber    String
  dob                DateTime
  designation        String
  gender             Gender
  genderOther        String? // Specify if gender is OTHER
  maritalStatus      MaritalStatus
  maritalStatusOther String? // Specify if marital status is OTHER

  // Contact & address
  addressId String?  @unique
  address   Address? @relation("EmployeeAddress", fields: [addressId], references: [id])

  // Emergency
  emergencyContact           String
  emergencyRelationship      Relationship
  emergencyRelationshipOther String? // Specify if relationship is OTHER

  // Professional
  department    String
  dateOfJoining DateTime
  experience    String
  workLocation  WorkLocation
  branchId      String
  branch        Branch        @relation(fields: [branchId], references: [id])
  employeeRole  EmployeeRole? @relation(fields: [employeeRoleId], references: [id])

  // Optional username if separate from `User`
  loanAssignments LoanAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], map: "fk_employee_user")

  @@index([employeeRoleId])
}

model EmployeeRole {
  id          String   @id @default(cuid())
  roleTitle   String
  roleFor     roleFor
  roleName    String   @unique
  description String?
  documentsRequired    String @default("") // Could be a URL or file   reference
  documentsOptions     String?  // e.g., "Mandatory", "Optional", "None"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]
}

enum roleFor {
Employee
Partner
}
model Partner {
  id     String @id @default(cuid())
  userId String @unique


  partnerId String @unique

  parentPartnerId String?
  parentPartner   Partner? @relation("PartnerHierarchy", fields: [parentPartnerId], references: [id])

  childPartners Partner[] @relation("PartnerHierarchy")

  companyName                String
  contactPerson              String
  alternateNumber            String?
  panNumber                  String
  partnerCode                String?
  constitutionType           ConstitutionType?
  onboardingDate             DateTime?
  gstNumber                  String?
  aadhaarNumber              String?
  registrationNo             String?
  documents                  Json?
  bankName                   String?
  accountHolder              String?
  accountNo                  String?
  ifsc                       String?
  upiId                      String?
  portalAccess               Boolean? @default(false)
  loginId                    String?
  accessType                 AccessType?
  assignedRelationshipManager String?
  branchMapping              String?
  productAccess              String[]
  payoutFrequency            PayoutFrequency?
  payoutType                 PayoutType?
  gstApplicable              Boolean? @default(false)
  tdsApplicable              Boolean? @default(false)
  maxPayoutCap               Float?
  commissionType             CommissionType
  commissionValue            Float?
  branchId                   String
  branch                     Branch              @relation(fields: [branchId], references: [id])
  leads                      Leads[]             @relation("PartnerLeads")
  isActive                   Boolean             @default(true)
  commission                 PartnerCommission[]
  establishedYear            Int?
  partnerType                PartnerType
  businessNature             String?
  addresses                  Address[]           @relation("PartnerAddresses")
  designation                String?
  businessCategory           String?
  specialization             String?
  totalEmployees             Int?
  annualTurnover             Float?
  businessRegistrationNumber String?
  paymentCycle               PaymentCycle
  minimumPayout              Float?
  taxDeduction               Float?
  targetArea                 String?
  totalLeadsSubmitted        Int?                @default(0)
  loginToSanctionRatio       Float?
  sanctionToDisbursementRatio Float?
  disbursementVolume        Float?
  rejectionRate             Float?
  fraudCasesCount           Int?
  qualityScore              Float?
  partnerRating             Float?
  totalReferrals             Int?                @default(0)
  activeReferrals            Int?                @default(0)
  commissionEarned           Float?              @default(0)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  // Relations
  loanApplications LoanApplication[]
  user             User              @relation(fields: [userId], references: [id])
}

model Address {
  id           String      @id @default(cuid())
  addressType  AddressType
  addressLine1 String
  addressLine2 String?
  city         String
  district     String
  state        String
  pinCode      String
  landmark     String?
  phoneNumber  String? // With STD Code

  // Relations to Customer and CoApplicant (can have multiple addresses)
  customerId          String?
  customer            Customer?             @relation(fields: [customerId], references: [id])
  coApplicantId       String?
  coApplicant         CoApplicant?          @relation(fields: [coApplicantId], references: [id])
  guarantorId         String?
  guarantor           Guarantor?            @relation(fields: [guarantorId], references: [id])
  partnerId           String?
  partner             Partner?              @relation("PartnerAddresses", fields: [partnerId], references: [id])
  occupationalDetails OccupationalDetails[] // For office/business addresses

  // Relations to other entities (one address per entity)
  employee        Employee?        @relation("EmployeeAddress")
  lead            Leads?           @relation("LeadAddress")
  technicalReport TechnicalReport? @relation("TechnicalReportAddress")
  properties      Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([coApplicantId])
  @@index([partnerId])
}

model PartnerCommission {
  id        String @id @default(cuid())
  partnerId String
  loanId    String @unique

  approvedAmount   Float
  commissionType   CommissionType
  commissionValue  Float
  commissionAmount Float

  status       CommissionStatus @default(PENDING)
  calculatedAt DateTime         @default(now())
  paidAt       DateTime?
  remarks      String?

  partner   Partner         @relation(fields: [partnerId], references: [id])
  loan      LoanApplication @relation(fields: [loanId], references: [id])
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([partnerId])
}

model Branch {
  id             String     @id @default(cuid())
  name           String
  code           String     @unique
  type           BranchType // MAIN | SUBSIDIARY 
  parentBranchId String? // null for main branches

  parentBranch          Branch?                @relation("BranchHierarchy", fields: [parentBranchId], references: [id])
  subBranches           Branch[]               @relation("BranchHierarchy")
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User[]
  partners              Partner[]
  employees             Employee[]
  loanApplications      LoanApplication[]
  loanRecoveries        LoanRecovery[]
  technicalReports      TechnicalReport[]
  legalReports          LegalReport[]
  sanction               Sanction[]
  documents             Document[]
  loanApplicationDrafts LoanApplicationDraft[]

  @@index([parentBranchId])
}

model Leads {
  id                         String            @id @default(cuid())
  fullName                   String
  contactNumber              String
  leadNumber                 String            @unique
  email                      String
  dob                        DateTime
  gender                     Gender
  partnerId                  String?
  loanAmount                 Float
  loanTypeId                 String
  addressId                  String?           @unique
  address                    Address?          @relation("LeadAddress", fields: [addressId], references: [id])
  assignedTo                 String?
  assignedBy                 String?
  convertedLoanApplicationId String?
  status                     LeadStatus        @default(PENDING)
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  // Relations  assignedToUser User? @relation("LeadAssignedTo", fields: [assignedTo], references
  partner                    Partner?          @relation("PartnerLeads", fields: [partnerId], references: [id])
  assignedToUser             User?             @relation("LeadAssignedTo", fields: [assignedTo], references: [id])
  assignedByUser             User?             @relation("LeadAssignedBy", fields: [assignedBy], references: [id])
  loanApplications           LoanApplication[]
  loanType                   LoanType          @relation(fields: [loanTypeId], references: [id])

  @@index([leadNumber])
}

model LoanApplicationDraft {
  id       String @id @default(cuid())
  userId   String
  branchId String

  draftData Json
  step      Int         @default(1) // to track which step of the application process the draft is in
  status    DraftStatus @default(DRAFT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])
}

model LoanApplication {
  id              String   @id @default(cuid())
  // leadId          String              @unique
  applicationDate DateTime @default(now())
  loanNumber      String   @unique

  // Office Use Section
  serviceCentre  String?
  processingFees Float?
  executiveName  String?
  EmployeeCode   String?
  schemeGroup    String?
  referrerFileNo String?

  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  // loanProductId   String
  leadId          String?
  lead            Leads?   @relation(fields: [leadId], references: [id])
  loanTypeId      String
  partnerId       String?
  ownerPartnerId  String?
  partner         Partner? @relation(fields: [partnerId], references: [id])
  requestedAmount Float
  approvedAmount  Float?
  tenureMonths    Int?
  interestRate    Float?

  interestType   InterestType
  emiAmount      Float?
  purposeDetails String?

  coapplicants    CoApplicant[]
  totalPayable    Float?
  loanPurpose     String?
  cibilScore      Int?
  status          LoanStatus    @default(application_in_progress)
  approvalDate    DateTime?
  activationDate  DateTime?
  rejectionReason String?
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  kycId           String?       @unique
  kyc             Kyc?          @relation(fields: [kycId], references: [id])

  //Emi charges

  //Disbursement Rules
  latePaymentFeeType CommissionType?
  latePaymentFee     Float? // amount or %
  bounceCharges      Float? // amount or %
  emiStartDate       DateTime?
  emiPaymentAmount   Float?

  foreclosureDate        DateTime?
  foreclosureChargesType CommissionType?
  foreclosureAllowed     Boolean         @default(true)
  foreclosureCharges     Float? // amount or %

  prepaymentChargeType CommissionType?
  prepaymentAllowed    Boolean             @default(true)
  prepaymentDate       DateTime?
  prepaymentCharges    Float? // amount or %
  defaultedAt          DateTime?
  dpd                  Int?
  // Relations
  documents            Document[]
  loanRecoveries       LoanRecovery[]
  loanDisbursement     LoanDisbursement[]
  technicalReports     TechnicalReport[]
  legalReports         LegalReport[]
  emis                 LoanEmiSchedule[]
  nachMandates         NachMandate[]
  foreClosures         foreClosure[]
  commissionPayments   PartnerCommission[]
  sanction             Sanction[]
  createdById          String?
  createdBy            User?               @relation(fields: [createdById], references: [id])
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  branchId             String
  branch               Branch              @relation(fields: [branchId], references: [id])

  // Relations
  loanType          LoanType?          @relation(fields: [loanTypeId], references: [id])
  loanAssignments   LoanAssignment[]
  guarantors        Guarantor[]
  existingLoans     ExistingLoan[]
  creditCards       CreditCard[]
  bankAccounts      BankAccount[]
  insurancePolicies InsurancePolicy[]
  properties        Property[]
  references        Reference[]
  loanRequirement   LoanRequirement?
  loanQuestionnaire LoanQuestionnaire?

  @@index([loanNumber])
}

model CoApplicant {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  // Personal Details
  firstName                 String
  lastName                  String
  middleName                String?
  fatherName                String?
  motherName                String?
  woname                    String?
  relation                  CoApplicantRelation
  relationOther             String? // Specify if relation is OTHER
  contactNumber             String
  phoneNumber               String?
  email                     String?
  dob                       DateTime
  category                  Category?
  maritalStatus             MaritalStatus?
  noOfDependents            Int?
  noOfChildren              Int?
  qualification             String?
  correspondenceAddressType CorrespondenceAddressType?
  panNumber                 String?
  aadhaarNumber             String?
  voterId                   String?
  drivingLicenceNo          String?
  passportNumber            String?
  presentAccommodation      AccommodationType?
  periodOfStay              String?
  rentPerMonth              Float?

  employmentType EmploymentType

  //kyc Details
  kycId String? @unique
  kyc   Kyc?    @relation("CoApplicantKyc", fields: [kycId], references: [id])

  // Relations
  addresses           Address[]
  occupationalDetails OccupationalDetails[]
  employmentDetails   EmploymentDetails[]
  financialDetails    CoApplicantFinancialDetails?
  documents           Document[]
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([loanApplicationId])
}

model CoApplicantFinancialDetails {
  id            String      @id @default(cuid())
  coApplicantId String      @unique
  coApplicant   CoApplicant @relation(fields: [coApplicantId], references: [id])

  grossMonthlyIncome     Float?
  netMonthlyIncome       Float?
  averageMonthlyExpenses Float?

  savingBankBalance        Float?
  valueOfImmovableProperty Float?
  currentBalanceInPF       Float?
  valueOfSharesSecurities  Float?
  fixedDeposits            Float?
  otherAssets              Float?
  totalAssets              Float?

  creditSocietyLoan Float?
  employerLoan      Float?
  homeLoan          Float?
  pfLoan            Float?
  vehicleLoan       Float?
  personalLoan      Float?
  otherLoan         Float?
  totalLiabilities  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//===================================CUSTOMER=====================================

model Customer {
  id                           String                     @id @default(cuid())
  title                        Title
  firstName                    String
  lastName                     String
  middleName                   String?
  fatherName                   String
  motherName                   String
  woname                       String? // Husband/Wife/Guardian name based on relation
  email                        String?
  dob                          DateTime
  contactNumber                String
  alternateNumber              String?
  category                     Category
  categoryOther                String? // Specify if category is OTHER
  maritalStatus                MaritalStatus
  maritalStatusOther           String? // Specify if marital status is OTHER
  // Additional Personal Details
  noOfFamilyDependents         Int?
  noOfChildren                 Int?
  qualification                String?
  correspondenceAddressType    CorrespondenceAddressType?
  aadhaarNumber                String
  panNumber                    String
  passportNumber               String?
  voterId                      String?
  drivingLicenceNo             String?
  gender                       Gender
  genderOther                  String? // Specify if gender is OTHER
  // Accommodation Details
  presentAccommodation         AccommodationType?
  periodOfStay                 String? // e.g., "2 years", "6 months"
  rentPerMonth                 Float?
  nationality                  String
  phoneNumber                  String? // With STD Code
  relationshipWithCoApplicant  CoApplicantRelation // Relation with co-applicant if any
  relationWithCoApplicantOther String? // Specify if relation is OTHER

  employmentType EmploymentType

  status CustomerStatus @default(ACTIVE)

  // Relations
  addresses        Address[]
  loanApplications LoanApplication[]
  loanRecoveries   LoanRecovery[]
  nachMandates     NachMandate[]
  creditReport     CreditReport?
  // kycs             CustomerKYC[]

  // Relations to new detailed tables
  occupationalDetails OccupationalDetails[]
  employmentDetails   EmploymentDetails[]
  financialDetails    FinancialDetails?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//===================================OCCUPATIONAL DETAILS=====================================

model OccupationalDetails {
  id            String       @id @default(cuid())
  customerId    String
  customer      Customer     @relation(fields: [customerId], references: [id])
  coApplicantId String?
  coApplicant   CoApplicant? @relation(fields: [coApplicantId], references: [id])
  guarantorId   String?
  guarantor     Guarantor?   @relation(fields: [guarantorId], references: [id])

  occupationalCategory      OccupationalCategory
  occupationalCategoryOther String? // Specify if category is OTHER

  // Common fields
  companyBusinessName String?
  addressId           String?
  address             Address?  @relation(fields: [addressId], references: [id])
  phoneNumber         String? // With STD Code
  extensionNumber     String?
  totalWorkExperience Int? // in years
  noOfEmployees       Int?
  commencementDate    DateTime? // Date of Commencement of Business/Profession

  // Professional specific
  professionalType    ProfessionalType?
  professionalSpecify String? // Other specify

  // Business specific
  businessType    BusinessType?
  businessSpecify String? // Other specify

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([coApplicantId])
  @@index([guarantorId])
}

//===================================EMPLOYMENT DETAILS (For Salaried)=====================================

model EmploymentDetails {
  id            String       @id @default(cuid())
  customerId    String
  customer      Customer     @relation(fields: [customerId], references: [id])
  coApplicantId String?
  coApplicant   CoApplicant? @relation(fields: [coApplicantId], references: [id])
  guarantorId   String?
  guarantor     Guarantor?   @relation(fields: [guarantorId], references: [id])

  employerType      EmployerType
  employerTypeOther String? // Specify if employer type is OTHER
  designation       String?
  department        String?
  dateOfJoining     DateTime?
  dateOfRetirement  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([coApplicantId])
  @@index([guarantorId])
}

//===================================FINANCIAL DETAILS=====================================

model FinancialDetails {
  id         String   @id @default(cuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  // Income & Expenses
  grossMonthlyIncome     Float
  netMonthlyIncome       Float
  averageMonthlyExpenses Float

  // Assets
  savingBankBalance        Float?
  valueOfImmovableProperty Float?
  currentBalanceInPF       Float?
  valueOfSharesSecurities  Float?
  fixedDeposits            Float?
  otherAssets              Float?
  totalAssets              Float?

  // Liabilities
  creditSocietyLoan Float?
  employerLoan      Float?
  homeLoan          Float?
  pfLoan            Float?
  vehicleLoan       Float?
  personalLoan      Float?
  otherLoan         Float?
  totalLiabilities  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//===================================GUARANTOR DETAILS=====================================
model Guarantor {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  firstName  String
  middleName String?
  lastName   String

  fatherName String?
  motherName String?
  woname     String?

  dob DateTime?

  contactNumber String?
  phoneNumber   String?
  email         String?

  panNumber      String?
  aadhaarNumber  String?
  voterId        String?
  drivingLicence String?
  passportNumber String?

  category      Category?
  maritalStatus MaritalStatus?

  noOfDependents Int?
  noOfChildren   Int?

  qualification             String?
  correspondenceAddressType CorrespondenceAddressType?
  relationshipWithApplicant CoApplicantRelation?
  relationshipOther         String?

  accommodationType AccommodationType?
  periodOfStay      String?
  rentPerMonth      Float?

  employmentType EmploymentType?

  kycId String? @unique
  kyc   Kyc?    @relation("GuarantorKyc", fields: [kycId], references: [id])

  addresses           Address[]
  occupationalDetails OccupationalDetails[]
  employmentDetails   EmploymentDetails[]
  financialDetails    GuarantorFinancialDetails?
  documents           Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//==============================GUARANTOR FINANCIAL DETAILS=====================================

model GuarantorFinancialDetails {
  id          String    @id @default(cuid())
  guarantorId String    @unique
  guarantor   Guarantor @relation(fields: [guarantorId], references: [id])

  grossMonthlyIncome     Float?
  netMonthlyIncome       Float?
  averageMonthlyExpenses Float?

  savingBankBalance        Float?
  valueOfImmovableProperty Float?
  currentBalanceInPF       Float?
  valueOfSharesSecurities  Float?
  fixedDeposits            Float?
  otherAssets              Float?
  totalAssets              Float?

  creditSocietyLoan Float?
  employerLoan      Float?
  homeLoan          Float?
  pfLoan            Float?
  vehicleLoan       Float?
  personalLoan      Float?
  otherLoan         Float?
  totalLiabilities  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//===================================EXISTING LOANS=====================================
model ExistingLoan {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  institutionName    String
  purpose            String?
  disbursedAmount    Float?
  emi                Float?
  balanceTerm        Int?
  balanceOutstanding Float?

  createdAt DateTime @default(now())
}

//===================================CREDIT CARD DETAILS=====================================
model CreditCard {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  holderName        String
  cardNumber        String
  issuingBank       String?
  holderSince       DateTime?
  creditLimit       Float?
  outstandingAmount Float?

  createdAt DateTime @default(now())
}

//===================================BANK ACCOUNT DETAILS=====================================

model BankAccount {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  holderName    String
  bankName      String
  branchName    String?
  accountType   String
  accountNumber String
  openingDate   DateTime?
  balanceAmount Float?

  createdAt DateTime @default(now())
}

//===================================INSURANCE POLICY DETAILS=====================================

model InsurancePolicy {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  issuedBy     String?
  branchName   String?
  holderName   String?
  policyNumber String?

  maturityDate  DateTime?
  policyValue   Float?
  policyType    String?
  yearlyPremium Float?
  paidUpValue   Float?

  createdAt DateTime @default(now())
}

//===================================PROPERTY DETAILS=====================================
model Property {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  propertySelected Boolean

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  landArea    Float?
  buildUpArea Float?

  ownershipType OwnershipType
  landType      LandType

  purchaseFrom  PurchaseSource
  purchaseOther String?

  constructionStage   ConstructionStage
  constructionPercent Float?

  createdAt DateTime @default(now())
}

//===================================REFERENCES=====================================
model Reference {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  name       String
  fatherName String?
  address    String?
  city       String?
  state      String?
  pinCode    String?
  phone      String?
  occupation String?

  createdAt DateTime @default(now())
}

//===================================LOAN REQUIREMENTS=====================================
model LoanRequirement {
  id                String          @id @default(cuid())
  loanApplicationId String          @unique
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  loanAmount Float?
  tenure     Int?

  interestOption InterestOption

  loanPurpose      LoanPurpose
  loanPurposeOther String?

  repaymentMethod RepaymentMethod

  createdAt DateTime @default(now())
}

//===========================LOAN QUESTIONNAIRE=====================================
model LoanQuestionnaire {
  id                String          @id @default(cuid())
  loanApplicationId String          @unique
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  legalPropertyClear Boolean?
  mortgagedElsewhere Boolean?
  residentOfIndia    Boolean?
  otherLoans         Boolean?
  guarantorAnywhere  Boolean?

  mppLifeInsurance Boolean?

  createdAt DateTime @default(now())
}

model LoanRecovery {
  id String @id @default(cuid())

  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  recoveryStage  recovery_stage
  recoveryStatus recovery_status

  totalOutstandingAmount Float
  recoveredAmount        Float
  balanceAmount          Float

  // Settlement fields 
  settlementAmount     Float?
  settlementDate       DateTime?
  settlementApprovedBy String?

  dpd         Int
  defaultedAt DateTime?

  assignedTo String?
  remarks    String?

  recoveryPayments RecoveryPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([loanApplicationId])
  @@index([branchId])
}

model RecoveryPayment {
  id String @id @default(cuid())

  loanRecoveryId String
  loanRecovery   LoanRecovery @relation(fields: [loanRecoveryId], references: [id])

  amount      Float
  paymentDate DateTime
  paymentMode PaymentMode
  referenceNo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([loanRecoveryId])
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userPermissions UserPermission[]
  rolePermissions RolePermission[]
}

model UserPermission {
  id           String  @id @default(cuid())
  userId       String
  permissionId String
  allowed      Boolean @default(true)

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([userId, permissionId])
}

model RolePermission {
  id           String  @id @default(cuid())
  role         Role
  permissionId String
  allowed      Boolean @default(true)

  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([role, permissionId])
}

model Document {
  id                 String             @id @default(cuid())
  loanApplicationId  String?
  coApplicantId      String?
  guarantorId        String?
  documentType       String
  documentPath       String
  verificationStatus VerificationStatus @default(pending)
  rejectionReason    String?
  kycId              String?
  branchId           String
  uploadedBy         String
  verified           Boolean            @default(false)
  verifiedBy         String?
  verifiedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  kyc                Kyc?               @relation("KycDocuments", fields: [kycId], references: [id])
  loanApplication    LoanApplication?   @relation(fields: [loanApplicationId], references: [id])
  coApplicant        CoApplicant?       @relation(fields: [coApplicantId], references: [id])
  guarantor          Guarantor?         @relation(fields: [guarantorId], references: [id])
  branch             Branch             @relation(fields: [branchId], references: [id])

  @@unique([coApplicantId, documentType]) // ✅ prevents duplicate uploads per co-applicant
  @@unique([guarantorId, documentType]) // ✅ prevents duplicate uploads per guarantor
  @@index([loanApplicationId, documentType]) // supports loan-level queries without forcing cross-party uniqueness
}

model Kyc {
  id              String           @id @default(cuid())
  loanApplication LoanApplication?
  documents       Document[]       @relation("KycDocuments")
  coApplicant     CoApplicant?     @relation("CoApplicantKyc")
  guarantor       Guarantor?       @relation("GuarantorKyc")
  userId          String
  status          KycStatus        @default(PENDING)
  remarks         String?

  verifiedBy String?
  verifiedAt DateTime?

  verifiedByUser User? @relation("KycVerifiedBy", fields: [verifiedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model RequiredKycDocument {
  id           String   @id @default(cuid())
  documentType String   @unique
  displayName  String?
  isActive     Boolean  @default(true)
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

model LoanEmiSchedule {
  id                String @id @default(cuid())
  loanApplicationId String
  loanNumber      String
  emiNo        Int
  emiStartDate DateTime? // EMI cycle start date
  dueDate      DateTime // EMI due date

  openingBalance     Float
  principalAmount    Float
  deferredPrincipal  Float  @default(0) // Principal deferred during INTEREST_ONLY moratorium
  interestAmount     Float
  emiAmount          Float // Scheduled EMI amount
  emiPaymentAmount   Float? // Actual amount paid (can be partial / excess)
  closingBalance     Float
  totalPayableAmount Float // principal + interest + late fees + bounce charges etc. 

  // Late & penalty
  latePaymentFeeType  LateFeeType @default(FIXED)
  latePaymentFee      Float       @default(0)
  bounceCharges       Float       @default(0) // NACH / cheque bounce charge
  bounceChargeApplied Boolean     @default(false)

  // -------- Payment Audit --------
  lastPaymentMode PaymentMode?
  chequeStatus    ChequeStatus?
  lastPaymentDate DateTime?

  status          EmiStatus       @default(pending)
  paidDate        DateTime?
  isDeferred      Boolean         @default(false)
  nachDebits      NachDebit[]
  loanApplication LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([loanApplicationId, emiNo])
  @@index([dueDate, status])
}

model EmiPayment {
  id            String      @id @default(cuid())
  emiScheduleId String
  amount        Float
  paymentDate   DateTime
  paymentMode   PaymentMode
}

model EmiMoratorium {
  id                String           @id @default(cuid())
  loanApplicationId String
  type              MoratoriumType
  startDate         DateTime
  endDate           DateTime
  interestAccrued   Float            @default(0)
  status            MoratoriumStatus @default(active)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model CreditReport {
  id                String         @id @default(cuid())
  customerId        String         @unique
  customer          Customer       @relation(fields: [customerId], references: [id])
  provider          CreditProvider //CIBIL | EXPERIAN | MOCK
  bureauReferenceId String? // CIBIL control number
  fetchedAt         DateTime       @default(now())

  // Core Score 
  creditScore Int?
  scoreBand   String? // e.g., Excellent, Good, Fair, Poor

  //loan Summary 
  totalAtiveLoans       Int?
  totalClosedLoans      Int?
  totalOutstandingLoans Float?
  totalMonthlyEmi       Float?

  //Risk Metrics 
  maxDPD          Int? //maximum days past due
  overdueAccounts Int?
  wittenOffCounts Int?
  settledCounts   Int?

  // Flags

  isThinFile Boolean @default(false)
  isNTC      Boolean @default(false) // New to Credit
  isValid    Boolean @default(true)
  isExpired  Boolean @default(false)
  pulledFor  String? // purpose of pulling the report 

  //Row Api Payload
  rowRawData    Json
  creditAccount CreditAccount[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([customerId])
  @@index([provider])
}

model CreditAccount {
  id               String       @id @default(cuid())
  creditReportId   String
  creditReport     CreditReport @relation(fields: [creditReportId], references: [id])
  lenderName       String
  accountType      String // PERSONAL_LOAN, CREDIT_CARD, HOME_LOAN etc.
  accountStatus    String // ACTIVE, CLOSED, SETTLED etc.
  sanctionedAmount Float?
  outstanding      Float?
  emiAmount        Float?
  dpd              Int? // days past due
  openedDate       DateTime?
  closedDate       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creditReportId])
}

model LoanType {
  id String @id @default(cuid())

  //Basic Identification 
  code        String  @unique // Personal Loan, Home Loan ,Vehicle Loan etc.
  name        String
  description String?

  //Classification 

  category LoanTypes
  secured  Boolean   @default(false)

  //Loan Limits 
  minAmount       Float
  maxAmount       Float
  minTenureMonths Int
  maxTenureMonths Int

  //Interest configuration

  interestType        InterestType
  minInterestRate     Float
  maxInterestRate     Float
  defaultInterestRate Float

  //processing & Charges

  minProcessingFee Float // amount or %
  maxProcessingFee Float // amount or %

  //login charges
  minLoginCharges Float? // amount or %
  maxLoginCharges Float? // amount or %

  gstApplicable Boolean @default(true)
  gstPercentage Float? //usually 18%

  //Eligibility Criteria 
  minAge         Int
  maxAge         Int
  minIncome      Float?
  employmentType EmploymentType?

  //Risk & Credit 

  minCibilScore Int?
  maxCibilScore Int?

  //Disbursement Rules
  maxLoanToValueRatio Float? //for secured loans

  prepaymentAllowed  Boolean @default(true)
  foreclosureAllowed Boolean @default(true)

  prepaymentCharges  Float? // amount or %
  foreclosureCharges Float? // amount or %

  //Emi charges
  latePaymentFeeType CommissionType?
  latePaymentFee     Float? // amount or %
  bounceCharges      Float? // amount or %

  //visibility & Control 

  isActive         Boolean @default(true)
  isPublic         Boolean @default(true)
  approvalRequired Boolean @default(true)

  //SLA & WorkFlow 
  estimatedProcessingTimeDays Int? //turnaround time
  otherDocumentsRequired           String //list of documents /comma separated 
  otherDocumentsOptions            String? // any optional documents that can help in faster processing

  // Applicant documents
  applicantDocumentsRequired String  @default("") // required docs for primary applicant (comma-separated)
  applicantDocumentsOptional String? // optional docs for primary applicant (comma-separated)

  // Co-Applicant documents
  coApplicantDocumentsRequired String  @default("") // required docs for co-applicant (comma-separated)
  coApplicantDocumentsOptional String? // optional docs for co-applicant (comma-separated)

  // Guarantor documents
  guarantorDocumentsRequired String  @default("") // required docs for guarantor (comma-separated)
  guarantorDocumentsOptional String? // optional docs for guarantor (comma-separated)

  //Audit Fields
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  leads            Leads[]
  loanApplications LoanApplication[]
}

model foreClosure {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])
  // Application metadata
  appliedBy             String?         // user id who applied
  appliedAt             DateTime?       // when application was created
  applicationNote       String?         // optional note provided by applicant

  // Computed breakup at time of application
  principalOutstanding  Float?          // outstanding principal at time of application
  interestAccrued       Float?          // accrued interest
  unpaidEmiCharges      Float?          // outstanding EMI charges (late / bounce)
  penalty               Float?          // foreclosure penalty amount (absolute)
  totalPayable          Float?          // sum of components (principal + interest + penalty + charges)

  // Approval & settlement
  approvalStatus        ForeclosureStatus @default(PENDING)
  foreclosureAmount     Float?          // final approved foreclosure amount
  foreclosureApprovedBy String?         // user id who approved
  foreclosureApprovedAt DateTime?

  settledAmount         Float?
  settledAt             DateTime?
  settlementReference   String?         // txn id / receipt reference
  paymentMode           PaymentMode?
  settlementReceiptUrl  String?
  approvedBy              String?         // user id who approved the settlement
  approvedAt              DateTime?
  rejectedBy              String?         // user id who rejected the application
  rejectedAt              DateTime?
  

  // Administrative
  reason                String?         // reason for rejection/notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([loanApplicationId])
  @@index([approvalStatus])
}

enum ForeclosureStatus {
  PENDING
  APPROVED
  REJECTED
}

model TechnicalReport {
  id                String          @id @default(cuid())
  loanApplicationId String
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  // Engineer / Valuer
  engineerId   String?
  engineerName String
  agencyName   String?

  //property details
  propertyType    String // Residential, Commercial, Land Flat Villa etc.
  propertyAddress String // Added for address line
  city            String // Added for city
  state           String // Added for state
  pincode         String // Added for pincode
  addressId       String?  @unique
  address         Address? @relation("TechnicalReportAddress", fields: [addressId], references: [id])

  //Valuation details
  marketValue      Float
  discussionValue  Float
  forcesdSaleValue Float?
  recommendedLtv   Float // % recommended by valuer

  // Construction

  constructionStatus    String // Completed, Under Construction, New Project 
  propertyAge           Int? // in years
  residualLife          Int? // in years
  qualityOfConstruction String? // Good, Average, Poor

  //Decidion
  status  ReportStatus @default(PENDING)
  remarks String?

  // Documents
  reportUrl       String? // link to technical report document
  sitePhotographs String? // link to site photographs document

  // Audit
  submittedAt DateTime?
  approvedBy  String?
  rejectedBy  String?
  approvedAt  DateTime?

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalReport {
  id                String           @id @default(cuid())
  loanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])
  loanApplicationId String?

  //Advocate 
  advocateId   String?
  advocateName String
  lawFirmName  String?

  //Title details
  ownerName       String
  ownershipType   String // SELF | JOINT | INHERITED
  titleClear      Boolean
  titleChainYears Int

  // Encumbrance details
  encumbranceFound   Boolean
  encumbranceDetails String?

  //Regulatory
  reraRegistered   Boolean?
  landUserClear    Boolean?
  buildingApproval Boolean?

  //Decidion
  status  ReportStatus @default(PENDING)
  remarks String?

  // Documents
  reportUrl String? // link to legal report document

  // Audit
  submittedAt DateTime?
  approvedBy  String?
  rejectedBy  String?
  rejectedAt  DateTime?

  approvedAt DateTime?

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([loanApplicationId])
}

model LoanAssignment {
  id                String       @id @default(cuid())
  loanApplicationId String
  employeeId        String
  role              AssignedRole
  isActive          Boolean      @default(true)
  assignedBy        String
  assignedAt        DateTime     @default(now())
  unassignedBy      String?
  unassignedAt      DateTime?

  loanApplication LoanApplication @relation(fields: [loanApplicationId], references: [id])
  employee        Employee        @relation(fields: [employeeId], references: [id])

  @@unique([loanApplicationId, employeeId, role])
  @@index([loanApplicationId, employeeId])
}

model AuditLog {
  id          String @id @default(cuid())
  entityType  String // LOAN | TECHNICAL_REPORT | LEGAL_REPORT
  entityId    String
  action      String // CREATED | SUBMITTED | APPROVED | REJECTED
  performedBy String

  branchId  String
  oldValue  Json?
  newValue  Json?
  remarks   String?
  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([branchId])
}

model SLAPolicy {
  id             String   @id @default(cuid())
  module         String // KYC | LEGAL | TECHNICAL | LOAN | RECOVERY
  stage          String // kyc_pending, under_review, etc.
  thresholdHours Int
  action         String // ESCALATE | NOTIFY | REASSIGN
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([module, stage])
  @@index([module])
}

model SLABreachLog {
  id          String   @id @default(cuid())
  entityType  String // LOAN | TECHNICAL_REPORT | LEGAL_REPORT | KYC
  entityId    String
  stage       String
  breachedAt  DateTime @default(now())
  escalatedTo String?
  remarks     String?
  branchId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([branchId])
}

model LoanDisbursement {
  id                   String             @id @default(cuid())

  // 🔗 Loan Reference
  loanNumber           String             @unique
  loanApplication      LoanApplication    @relation(fields: [loanNumber], references: [id])

  // 💰 Financial Details
  amount               Float
  principalAmount      Float            // optional breakup
  interestAmount       Float            // optional breakup
  chargesAmount        Float?            // processing / fees

  currency             String             @default("INR")

  // 🏦 Disbursement Details
  disbursementMode     DisbursementMode
  disbursementStatus   DisbursementStatus @default(PENDING)
  disbursementDate     DateTime           @default(now())
  valueDate            DateTime?          // bank settlement date

  // 🔁 Transaction Details
  transactionReference String             @unique
  externalTxnId        String?            // from payment gateway / bank
  utrNumber            String            // UTR for NEFT/RTGS/IMPS

  // 🏛️ Bank Details
  bankName             String
  bankAccountNumber    String
  ifscCode             String
  accountHolderName    String

  // 🧾 Internal Tracking
  processedBy          String
  approvedBy           String?            // maker-checker system
  rejectedBy           String?
  rejectionReason      String?

  // 🔐 Compliance & Audit
  isReversed           Boolean            @default(false)
  reversedAt           DateTime?
  reversalReason       String?

  // 📝 Remarks
  remarks              String?

  // 📊 Metadata
  metadata             Json?

  // ⏱️ Timestamps
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // 📌 Indexes
  @@index([loanNumber])
  @@index([transactionReference])
  @@index([disbursementStatus])
}



model NachMandate {
  id                String          @id @default(cuid())
  loanApplicationId String
  customerId        String
  bankName          String
  accountNumber     String
  ifscCode          String
  maxDebitAmount    Float
  startDate         DateTime
  endDate           DateTime
  status            NachStatus      @default(PENDING)
  failureCount      Int             @default(0)
  lastDebitDate     DateTime?
  debits            NachDebit[]
  customer          Customer        @relation(fields: [customerId], references: [id])
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([loanApplicationId])
}

model NachDebit {
  id              String          @id @default(cuid())
  mandateId       String
  emiId           String
  debitAmount     Float
  debitDate       DateTime
  status          DebitStatus     @default(PENDING)
  bankReferenceId String?
  failureReason   String?
  mandate         NachMandate     @relation(fields: [mandateId], references: [id])
  emiSchedule     LoanEmiSchedule @relation(fields: [emiId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([mandateId])
  @@index([emiId])
}

model Sanction {
  id                String   @id @default(cuid())
  loanApplicationNumber String
  loanApplication   LoanApplication @relation(fields: [loanApplicationNumber], references: [loanNumber])

  sanctionedAmount  Float
  currency          String   @default("INR")
  approvedBy        String?
  approvedAt        DateTime?
  status            SanctionStatus @default(PENDING)
  remarks           String?

  // documents links or json metadata
  documents Json?

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([loanApplicationNumber])
  @@index([branchId])
}

enum SanctionStatus {
  PENDING
  APPROVED
  REJECTED
  PARTIAL
}

